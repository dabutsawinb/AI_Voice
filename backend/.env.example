# ════════════════════════════════════
#  AI Voice Studio — Environment Variables
#  คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่า
# ════════════════════════════════════

# ── Server ──
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# ── AI Paths ──
APPLIO_PATH=../ai-engines/Applio

# ── Smart Note API Keys ──
# AssemblyAI — สมัครฟรีได้ที่ https://www.assemblyai.com
# มี free tier 100 ชั่วโมง/เดือน
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# Google Gemini — สมัครฟรีได้ที่ https://aistudio.google.com
# มี free tier ใช้ได้ไม่จำกัด (rate limit)
GEMINI_API_KEY=your_gemini_key_here
