# ─────────────────────────────────────────────────────────
# AI Voice Studio — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── Backend ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── AI Engine Paths ──
# Clone GPT-SoVITS here: https://github.com/RVC-Boss/GPT-SoVITS
GPT_SOVITS_PATH=./ai-engines/GPT-SoVITS

# Clone RVC here: https://github.com/RVC-Project/Retrieval-based-Voice-Conversion-WebUI
RVC_PATH=./ai-engines/RVC

# ── Model storage ──
RVC_MODELS_DIR=./backend/models_store/rvc
TTS_MODELS_DIR=./backend/models_store/tts

# ── Audio output ──
OUTPUT_DIR=./backend/outputs
MAX_AUDIO_DURATION_SEC=600
SAMPLE_RATE=44100

# ── GPU (leave empty for CPU) ──
# CUDA_VISIBLE_DEVICES=0
